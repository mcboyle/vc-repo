 	static shared_ptr <Pkcs5Kdf> FindKdfAlgorithm (const wxString &name)
 	{
 		foreach (shared_ptr <Pkcs5Kdf> kdf, Pkcs5Kdf::GetAvailableAlgorithms())
@@ -110,6 +139,11 @@ namespace VeraCrypt
