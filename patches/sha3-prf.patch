+	unsigned char *d,		/* input data; d is guaranteed to be at least 64 bytes long */
+	int ld,			/* length of input data in bytes */
+	hmac_sha3_512_ctx* hmac	/* HMAC-SHA3-512 context which holds temporary variables */
+)
