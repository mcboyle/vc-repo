+uint32 Argon2IterationsForBudget (uint32 targetMs, uint32 perIterMicros, uint32 floorIters, uint32 capIters);
+uint32 Argon2CalibrateToTime (uint32 targetMs, uint32 memCostKiB, uint32 probeIters,
