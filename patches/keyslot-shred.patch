# keyslot-shred.patch — verifiable keyslot shredding + attestation (ROI-TOP-50 item 41)
#
# Apply with `git apply -p1` from the REPOSITORY ROOT. Gated behind VC_ENABLE_KEYSLOT_SHRED (on top of
# VC_ENABLE_KEYSLOTS); default build unaffected.
#
#   * Common/KeyslotStore.{c,h}: KeyslotShred hashes the slot before, overwrites the entire stride
#     (ciphertext + AF stripes + salt + tag) with CSPRNG random, reads back what actually landed, and
#     returns attestation = SHA256("VCKSSHRED1" || index || H(before) || H(after)).
#   * verification/keyslot_shred_test.c + build_and_verify.sh step [63]: proves the shredded slot won't
#     open, carries no verbatim remnant, and the attestation is independently reproducible. Negative
#     control: a weak mark-free (clear only the magic) leaves the ciphertext recoverable verbatim.
#   * flag_matrix.sh: sweeps the new flag.
#
# Verified: suite --strict "62/62 steps verified, 0 skipped"; flag matrix 160/160; gcc-13 + clang-18.
# Honest limit (docs): logical overwrite; on SSD/CoW media the physical block may persist.
#
diff --git a/src/Common/KeyslotStore.c b/src/Common/KeyslotStore.c
index 8d173d8..959646c 100644
--- a/src/Common/KeyslotStore.c
+++ b/src/Common/KeyslotStore.c
@@ -342,6 +342,44 @@ int KeyslotRevoke (const KeyslotStoreCfg *cfg, KeyslotArea *area, int index)
 	return area->write (area->ctx, (uint64) index * KEYSLOT_TABLE_STRIDE, rec, sizeof (rec));
 }
 
+#if defined(VC_ENABLE_KEYSLOT_SHRED)
+int KeyslotShred (const KeyslotStoreCfg *cfg, KeyslotArea *area, int index,
+                  unsigned char attestation[32])
+{
+	unsigned char rec[KEYSLOT_TABLE_STRIDE];
+	unsigned char hOld[32], hNew[32];
+	unsigned char msg[10 + 4 + 32 + 32];
+	uint64 off;
+
+	if (index < 0 || (uint64) index >= n_slots (cfg, area))
+		return -1;
+	off = (uint64) index * KEYSLOT_TABLE_STRIDE;
+
+	if (area->read (area->ctx, off, rec, sizeof (rec)) != 0)      /* hash the slot BEFORE */
+		return -1;
+	sha256 (hOld, rec, sizeof (rec));
+
+	cfg->randBytes (rec, sizeof (rec));                            /* overwrite the ENTIRE stride */
+	if (area->write (area->ctx, off, rec, sizeof (rec)) != 0)
+		return -1;
+
+	if (area->read (area->ctx, off, rec, sizeof (rec)) != 0)      /* read back what ACTUALLY landed */
+		return -1;
+	sha256 (hNew, rec, sizeof (rec));
+
+	/* attestation = SHA256("VCKSSHRED1" || index_be32 || H(before) || H(after)) */
+	memcpy (msg, "VCKSSHRED1", 10);
+	msg[10] = (unsigned char) (index >> 24); msg[11] = (unsigned char) (index >> 16);
+	msg[12] = (unsigned char) (index >> 8);  msg[13] = (unsigned char) index;
+	memcpy (msg + 14, hOld, 32);
+	memcpy (msg + 46, hNew, 32);
+	sha256 (attestation, msg, sizeof (msg));
+
+	ks_wipe (rec, sizeof (rec));
+	return 0;
+}
+#endif
+
 int KeyslotCount (const KeyslotStoreCfg *cfg, KeyslotArea *area)
 {
 	unsigned char hdr[4];
