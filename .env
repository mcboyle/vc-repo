# .env — build & verification configuration for this VeraCrypt fork (Claude Code cloud sandbox).
#
# This file holds NO secrets — only build knobs and paths — so it is committed on purpose (the fork
# has no API keys or credentials). `source .env` in a shell, or let .claude/hooks/session-start.sh
# (the SessionStart setup script) persist the key vars + install deps when a cloud sandbox starts.
#
# Full dependency set for a real product build (the setup hook installs these best-effort):
#   apt: libwxgtk3.2-dev libpcsclite-dev libfido2-dev libfuse3-dev yasm build-essential pkg-config
#        (+ libykpers-1-dev for YubiKey). libpcsclite-dev + yasm are STOCK VeraCrypt deps, not the
#        fork's — without them the build stops in upstream smartcard/asm code. If yasm is absent,
#        add NOASM=1 to the make line to use the portable C implementations.
#   The verification suite (verification/build_and_verify.sh) needs only clang/gcc + python3.

# --- paths ---
export VC_SRC="src"                 # VeraCrypt source tree (build here: cd "$VC_SRC" && make ...)
export VC_VERIFY="verification"     # self-contained proof suite: ./build_and_verify.sh

# --- verification toolchain ---
# clang is preferred: gcc hard-errors on Crypto/chacha256.c's duplicate 'static'. The suite already
# picks clang first; this mirrors it for ad-hoc object builds.
export CC="${CC:-clang}"

# --- product-build feature flags (all opt-in; a plain `make` stays byte-for-byte stock) ---
# Pass these on the make command line, e.g.:
#   cd src && make NOGUI=1 KEYSLOTS=1 KEYSCRUB=1 DURESS=1 ARGON2PARAMS=1 BALLOON=1 SHAMIRMAC=1 SHARECODE=1 HKF=1
# Reference (knob -> define -> what it turns on):
#   KEYSCRUB=1      -> VC_ENABLE_KEYSCRUB       cross-platform RAM key scrub          (docs/MEMORY-SCRUB.md)
#   DURESS=1        -> VC_ENABLE_DURESS         duress-passphrase safe dismount       (docs/DURESS-DISMOUNT-SPEC.md)
#   KEYSLOTS=1      -> VC_ENABLE_KEYSLOTS       multi-keyslot + AF-split + area I/O    (docs/KEYSLOTS-SPEC.md, AF-SPLIT-SPEC.md)
#   ARGON2PARAMS=1  -> VC_ENABLE_ARGON2_PARAMS  explicit Argon2id memory/time/parallel (docs/ARGON2-PARAMS-SPEC.md)
#   BALLOON=1       -> VC_ENABLE_BALLOON_KDF    Balloon as a selectable --hash        (docs/BALLOON-SPEC.md)
#   SHAMIRMAC=1     -> VC_ENABLE_SHAMIR_MAC     keyed per-share MAC                    (docs/VSS-SPEC.md)
#   SHARECODE=1     -> VC_ENABLE_SHARECODE      bech32 transcribable share encoding   (docs/VSS-SPEC.md)
#   HKF=1           -> VC_ENABLE_HKF            hardware/threshold key-factor + CLI    (docs/HARDWARE-2FA.md)
#   HKF_SIMULATOR=1 -> + VC_ENABLE_HKF_SIMULATOR  software token — TESTING ONLY, never ship
#   YUBIKEY=1       -> + VC_ENABLE_YUBIKEY_HMAC   YubiKey backend (needs libykpers-1-dev, links -lykpers-1)
#   FIDO2=1         -> + VC_ENABLE_FIDO2          FIDO2 backend   (needs libfido2-dev,   links -lfido2)
#   HKF_SALT_BIND=1 -> VC_ENABLE_HKF_SALT_BIND  RAW_SECRET binds to the volume salt    (docs/SALT-BINDING-SPEC.md)
# IMPORTANT: `make clean` when changing feature flags — make does not rebuild objects on -D changes,
# and a stale mixed binary silently drops derivation hooks (docs/REAL-BUILD-VALIDATION.md).

# Convenience defaults for a full-featured NOGUI build (uncomment to use with `make $VC_MAKE_FLAGS`):
export VC_MAKE_FLAGS="NOGUI=1 KEYSLOTS=1 KEYSCRUB=1 DURESS=1 ARGON2PARAMS=1 BALLOON=1 SHAMIRMAC=1 SHARECODE=1"
